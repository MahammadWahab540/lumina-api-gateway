NODE_ENV=development
PORT=3000
LOG_LEVEL=info
BODY_LIMIT_MB=2
CORS_ORIGINS=*

# Supabase Auth
SUPABASE_JWKS_URI=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Supabase Data
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Microservice URLs
AUTH_SERVICE_URL=http://auth-service.railway.internal:3001
TENANT_SERVICE_URL=http://tenant-service.railway.internal:3003
USER_SERVICE_URL=http://user-service.railway.internal:3004
COURSE_SERVICE_URL=http://course-service.railway.internal:3005
ENROLLMENT_SERVICE_URL=http://enrollment-service.railway.internal:3006
ASSIGNMENT_SERVICE_URL=http://assignment-service.railway.internal:3007
SKILL_SERVICE_URL=http://skill-service.railway.internal:3008
AI_SERVICE_URL=http://ai-service.railway.internal:3002
GAMIFICATION_SERVICE_URL=http://gamification-service.railway.internal:3009
ANALYTICS_SERVICE_URL=http://analytics-service.railway.internal:3010
NOTIFICATION_SERVICE_URL=http://notification-service.railway.internal:3011
PERSONALIZATION_SERVICE_URL=http://personalization-service.railway.internal:3012
OPENMAIC_SERVICE_URL=https://openmaic.example

# Voice Discovery AgentScope service
VOICE_DISCOVERY_SERVICE_URL=http://localhost:8002
INTERNAL_SERVICE_KEY=change-me-internal-service-key

# Proxy
PROXY_TIMEOUT_MS=10000

# Rate Limiting
RATE_LIMIT_GLOBAL_TTL=60000
RATE_LIMIT_GLOBAL_LIMIT=120
RATE_LIMIT_AUTH_TTL=60000
RATE_LIMIT_AUTH_LIMIT=30
RATE_LIMIT_AI_TTL=60000
RATE_LIMIT_AI_LIMIT=20
RATE_LIMIT_REST_TTL=60000
RATE_LIMIT_REST_LIMIT=60
RATE_LIMIT_STORAGE_TTL=60000
RATE_LIMIT_STORAGE_LIMIT=100
RATE_LIMIT_OPENMAIC_TTL=60000
RATE_LIMIT_OPENMAIC_LIMIT=60
RATE_LIMIT_VOICE_TTL=60000
RATE_LIMIT_VOICE_LIMIT=10

# Public Routes (comma-separated)
PUBLIC_ROUTES=/auth/login,/auth/refresh
