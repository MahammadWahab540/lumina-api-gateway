{
  "name": "lumina-api-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Lumina API Gateway built with NestJS + Fastify",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10"
  },
  "packageManager": "npm@10",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/reply-from": "^9.8.0",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.20",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/throttler": "^6.4.0",
    "ioredis": "^5.8.1",
    "jwks-rsa": "^3.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.20",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
